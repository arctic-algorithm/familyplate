# Copy to `.env.familyplate-b4ba9` (replace with your Firebase project id) for deploy.
# Production API key should use: firebase functions:secrets:set RESEND_API_KEY

# Local / optional — Resend API Key (https://resend.com). Prefer secrets in production.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "From" — must be on a domain verified in Resend
FROM_EMAIL=FamilyPlate <meals@yourdomain.com>

# Public app URL (email buttons + confirm/unsubscribe links)
APP_URL=https://your-familyplate-app.vercel.app

# Firebase Realtime Database URL
FIREBASE_DB_URL=https://familyplate-b4ba9-default-rtdb.firebaseio.com
